# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:pass@host/dbname?sslmode=require"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Google OAuth
#   Authorized redirect URI in Google Cloud Console:
#   ${NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Email (Magic Link) — Resend recommended
EMAIL_SERVER_HOST="smtp.resend.com"
EMAIL_SERVER_PORT="465"
EMAIL_SERVER_USER="resend"
EMAIL_SERVER_PASSWORD=""
EMAIL_FROM="noreply@nopersonai.com"

# Anthropic (Claude)
ANTHROPIC_API_KEY=""

# OpenAI (Whisper transcription)
OPENAI_API_KEY=""

# Twilio WhatsApp
#   Webhook URL to configure in Twilio:
#   ${NEXTAUTH_URL}/api/whatsapp/webhook
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"
TWILIO_WHATSAPP_SANDBOX_JOIN_CODE=""

# Meta Pixel (optional — leave empty to disable tracking)
NEXT_PUBLIC_META_PIXEL_ID=""

# LinkedIn OAuth + Scheduling
# Create an app at https://www.linkedin.com/developers/apps
# Add redirect URI: ${NEXTAUTH_URL}/api/auth/callback/linkedin
# Required products: "Sign In with LinkedIn using OpenID Connect" + "Share on LinkedIn" (w_member_social)
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""

# Cron secret for /api/cron/publish-scheduled — Vercel Cron sends this automatically
CRON_SECRET=""
